[
  {
    "label": "Debug app",
    "build": {
      "command": "pwsh.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${ZED_WORKTREE_ROOT}/tools/build.ps1"
      ],
      "cwd": "${ZED_WORKTREE_ROOT}"
    },
    "program": "${ZED_WORKTREE_ROOT}/build/Debug/simurator.exe",
    "request": "launch",
    "args": ["--route", "${ZED_WORKTREE_ROOT}/data/sample/route.json"],
    "adapter": "CodeLLDB"
  }
]
